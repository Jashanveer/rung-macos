<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BackendBaseURL</key>
	<string>https://rung-backend-dev.fly.dev</string>
	<!-- Permits HTTP loads to localhost / *.local / private LAN IPs so the
	     `-BackendBaseURL http://localhost:8080` launch-arg toggle works
	     even on signed/sandboxed builds. App Review-clean. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
